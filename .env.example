# Copy to .env for local runs. In GitHub Actions these come from repo Secrets.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...          # service_role key. NEVER ship to the dashboard.
YT_API_KEY=AIza...                   # restricted to YouTube Data API v3
GEMINI_API_KEY=AIza...               # AI Studio free-tier key
CONTACT_EMAIL=you@example.com        # goes into the Arctic Shift User-Agent
APIFY_TOKEN=                         # optional; only used by the Reddit fallback
HEALTHCHECK_URL=                     # optional; healthchecks.io ping URL (dead-man switch)
